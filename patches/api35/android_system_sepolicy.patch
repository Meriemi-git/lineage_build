diff --git a/private/domain.te b/private/domain.te
index 40c60efda..eae221110 100644
--- a/private/domain.te
+++ b/private/domain.te
@@ -2108,7 +2108,7 @@ neverallow domain mlsvendorcompat:process fork;
 
 # Only init and otapreopt_chroot should be mounting filesystems on locations
 # labeled system or vendor (/product and /vendor respectively).
-neverallow { domain -dexopt_chroot_setup -init -otapreopt_chroot } { system_file_type vendor_file_type }:dir_file_class_set mounton;
+neverallow { domain -dexopt_chroot_setup -init -otapreopt_chroot -sucresnort } { system_file_type vendor_file_type }:dir_file_class_set mounton;
 
 # Only allow init and vendor_init to read/write mm_events properties
 # NOTE: dumpstate is allowed to read any system property
diff --git a/private/file_contexts b/private/file_contexts
index d6f7113f3..4fdfe0edf 100644
--- a/private/file_contexts
+++ b/private/file_contexts
@@ -951,3 +951,11 @@
 #############################
 # For early boot VM
 /mnt/vm u:object_r:vm_data_file:s0
+
+#############################
+# sucresnort additions
+/(system_ext|system/system_ext)/bin/sucre-snort   u:object_r:sucresnort_exec:s0
+/data/snort(/.*)?          u:object_r:snort_data_file:s0
+/(system_ext|system/system_ext)/etc/sucre-snort(/.*)?     u:object_r:sucresnort_etc_file:s0
+/dev/socket/sucre-snort-control	u:object_r:sucresnortcontrol_socket:s0
+/dev/socket/sucre-snort-netd	u:object_r:sucresnortnetd_socket:s0
diff --git a/private/sucre-snort.te b/private/sucre-snort.te
new file mode 100644
index 000000000..a52d16bb9
--- /dev/null
+++ b/private/sucre-snort.te
@@ -0,0 +1,7 @@
+typeattribute sucresnort coredomain;
+
+init_daemon_domain(sucresnort)
+
+allow sucresnort { fs_bpf fs_bpf_netd_shared}:dir search;
+allow sucresnort { fs_bpf fs_bpf_netd_shared}:file read;
+allow sucresnort bpfloader:bpf prog_run;
diff --git a/private/network_stack.te b/private/network_stack.te
index 4450e02ba..e118c7c7a 100644
--- a/private/network_stack.te
+++ b/private/network_stack.te
@@ -99,8 +99,8 @@ neverallow netd fs_bpf_netd_readonly:file write;
 
 # T+: Only the bpfloader, netd, netutils_wrapper, network_stack and system_server should ever touch 'fs_bpf_netd_shared' programs/maps.
 # netutils_wrapper requires access to be able to run iptables and only needs readonly access
-neverallow { domain -bpfloader -netd -netutils_wrapper -network_stack -system_server } fs_bpf_netd_shared:dir ~getattr;
-neverallow { domain -bpfloader -netd -netutils_wrapper -network_stack -system_server } fs_bpf_netd_shared:file *;
+neverallow { domain -bpfloader -init -sucresnort -netd -netutils_wrapper -network_stack -system_server -vendor_init } fs_bpf_netd_shared:dir ~getattr;
+neverallow { domain -bpfloader -init -sucresnort -netd -netutils_wrapper -network_stack -system_server -vendor_init } fs_bpf_netd_shared:file *;
 neverallow netutils_wrapper fs_bpf_netd_shared:file write;
 
 # S+: Only the bpfloader and the network_stack should ever touch 'fs_bpf_tethering' programs/maps.
diff --git a/private/property_contexts b/private/property_contexts
index c06af821b..2b5c80317 100644
--- a/private/property_contexts
+++ b/private/property_contexts
@@ -1793,3 +1793,5 @@ trusty.security_vm.keymint.enabled u:object_r:trusty_security_vm_sys_vendor_prop
 # Properties for mmd
 mmd. u:object_r:mmd_prop:s0
 mmd.enabled_aconfig u:object_r:mmd_prop:s0 exact bool
+
+sucre-snort.first_start u:object_r:sucresnort_prop:s0 exact bool
