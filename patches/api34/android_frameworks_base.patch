+        private final LocalSocketAddress mSucreSnortAddress = new LocalSocketAddress(
+                "sucre-snort-control", LocalSocketAddress.Namespace.RESERVED);
+
+        private void sucreSnortSendCommand(String command) {
+            final LocalSocket socket = new LocalSocket(LocalSocket.SOCKET_STREAM);
+            try {
+                socket.connect(mSucreSnortAddress);
+            } catch (IOException e) {
+                Log.e(TAG, "Cannot connect to sucre-snort-control socket");
+            }
+
+            if (socket.isConnected()) {
+                try {
+                    socket.getOutputStream().write(command.getBytes());
+                } catch (IOException e) {
+                    Log.e(TAG, "Cannot write to sucre-snort-control socket");
+                }
+            }
+
+             try {
+                socket.close();
+            } catch (IOException e) {
+            }
+        }
+
+        public void sucreSnortSendTopActivity(int uid) {
+            sucreSnortSendCommand("TOPACTIVITY " + uid);
+        }
