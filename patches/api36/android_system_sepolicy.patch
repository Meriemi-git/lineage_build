diff --git a/prebuilts/api/202404/public/sucre-snort.te b/prebuilts/api/202404/public/sucre-snort.te
new file mode 100644
index 000000000..2b884dc96
--- /dev/null
+++ b/prebuilts/api/202404/public/sucre-snort.te
@@ -0,0 +1,57 @@
+type sucresnort, domain, mlstrustedsubject;
+type sucresnort_exec, exec_type, file_type, system_file_type;
+
+net_domain(sucresnort)
+
+# iptables
+
+allow sucresnort system_file:file { lock execute_no_trans };
+allow sucresnort shell_exec:file rx_file_perms;
+allow sucresnort self:global_capability_class_set {
+    net_raw
+    net_admin
+};
+dontaudit sucresnort system_file:dir write;
+
+# package list
+
+allow sucresnort packages_list_file:file r_file_perms;
+
+# sockets
+
+allow sucresnort self:netlink_netfilter_socket create_socket_perms_no_ioctl;
+allow sucresnort proc_net:file r_file_perms;
+unix_socket_connect(platform_app, sucresnortcontrol, sucresnort);
+unix_socket_connect(system_server, sucresnortcontrol, sucresnort);
+unix_socket_connect(netd, sucresnortnetd, sucresnort);
+
+# default config
+
+r_dir_file(sucresnort, sucresnort_etc_file)
+
+# saved data
+
+allow sucresnort snort_data_file:dir create_dir_perms;
+allow sucresnort snort_data_file:file create_file_perms;
+
+# system properties
+
+get_prop(sucresnort, boot_status_prop);
+set_prop(sucresnort, sucresnort_prop);
+set_prop(init, sucresnort_prop);
+
+# network interfaces
+
+r_dir_file(sucresnort, sysfs_net)
+
+# default apps management
+
+allow sucresnort package_service:service_manager find;
+binder_call(sucresnort, servicemanager)
+binder_call(sucresnort, system_server)
+binder_call(system_server, sucresnort)
+selinux_check_access(sucresnort)
+allow sucresnort toolbox_exec:file rx_file_perms;
+allow sucresnort tmpfs:dir create_dir_perms;
+allow sucresnort system_file:dir mounton;
+allow sucresnort self:capability sys_admin;
